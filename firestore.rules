rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function hasUser() { return signedIn() && exists(userPath()); }
    function user() { return get(userPath()).data; }
    function isAdmin() { return hasUser() && user().role == "admin" && user().active == true; }

    function enrollmentPath(courseId) {
      return /databases/$(database)/documents/enrollments/$(request.auth.uid + "_" + courseId);
    }
    function isEnrolled(courseId) {
      return signedIn()
        && exists(enrollmentPath(courseId))
        && get(enrollmentPath(courseId)).data.userId == request.auth.uid
        && get(enrollmentPath(courseId)).data.courseId == courseId
        && get(enrollmentPath(courseId)).data.status == "active";
    }
    function publicCourse() {
      return signedIn() && resource.data.active == true && resource.data.visible == true;
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list, create, update: if isAdmin();
      allow delete: if false;
    }

    match /courses/{courseId} {
      allow get: if isAdmin() || isEnrolled(courseId) || publicCourse();
      allow list: if isAdmin() || publicCourse();
      allow create, update: if isAdmin();
      allow delete: if false;

      match /modules/{moduleId} {
        allow read: if isAdmin() || isEnrolled(courseId);
        allow create, update: if isAdmin();
        allow delete: if false;

        match /lessons/{lessonId} {
          allow read: if isAdmin() || isEnrolled(courseId);
          allow create, update: if isAdmin();
          allow delete: if false;
        }
      }
    }

    match /enrollments/{enrollmentId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /certificates/{certificateId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /progress/{progressId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if validProgress(progressId);
      allow update: if validProgress(progressId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.courseId == resource.data.courseId
        && request.resource.data.moduleId == resource.data.moduleId
        && request.resource.data.lessonId == resource.data.lessonId;
      allow delete: if false;
    }

    function validProgress(progressId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          "userId", "courseId", "moduleId", "lessonId", "status", "completedAt", "type"
        ])
        && request.resource.data.keys().hasAll([
          "userId", "courseId", "moduleId", "lessonId", "status", "completedAt", "type"
        ])
        && request.resource.data.userId == request.auth.uid
        && progressId == request.auth.uid + "_" + request.resource.data.courseId + "_" + request.resource.data.lessonId
        && request.resource.data.status == "completed"
        && request.resource.data.type in ["manual", "video_auto"]
        && isEnrolled(request.resource.data.courseId)
        && exists(/databases/$(database)/documents/courses/$(request.resource.data.courseId)/modules/$(request.resource.data.moduleId)/lessons/$(request.resource.data.lessonId));
    }

    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly(["name", "email", "whatsapp", "consent", "source", "status", "createdAt"])
        && request.resource.data.name is string && request.resource.data.name.size() >= 2 && request.resource.data.name.size() <= 100
        && request.resource.data.email is string && request.resource.data.email.size() >= 5 && request.resource.data.email.size() <= 254
        && request.resource.data.whatsapp is string && request.resource.data.whatsapp.size() >= 8 && request.resource.data.whatsapp.size() <= 30
        && request.resource.data.consent == true
        && request.resource.data.source in ["landing-page", "turma-pioneira-op-01"]
        && request.resource.data.status == "new"
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      allow update: if isAdmin()
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
            && request.resource.data.updatedAt == request.time
            && (
              (resource.data.status == "new" && request.resource.data.status in ["contacted", "archived"])
              || (resource.data.status == "contacted" && request.resource.data.status in ["converted", "archived"])
              || (resource.data.status == "archived" && request.resource.data.status == "new")
            )
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["enrolled", "enrolledAt"])
            && resource.data.status == "converted"
            && request.resource.data.status == "converted"
            && request.resource.data.enrolled == true
            && request.resource.data.enrolledAt == request.time
            && (!resource.data.keys().hasAny(["enrolled"]) || resource.data.enrolled == false)
          )
        );
      allow delete: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
